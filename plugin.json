{
  "id": "bongoCat",
  "name": "Bongo Cat",
  "description": "A reactive Bongo Cat that taps along with your typing",
  "version": "2.0.1",
  "license": "MIT",
  "author": "Loc Huynh",
  "icon": "pets",
  "type": "composite",
  "capabilities": [
    "daemon",
    "dankbar-widget",
    "desktop-widget"
  ],
  "components": {
    "daemon": "./BongoDaemon.qml",
    "widget": "./BongoWidget.qml",
    "desktop": "./BongoDesktopWidget.qml"
  },
  "settings": "./BongoSettings.qml",
  "permissions": [
    "settings_read",
    "settings_write",
    "process"
  ],
  "requires_dms": ">=1.5.0"
}
